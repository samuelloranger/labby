{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@server/*": ["./src/server/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*"]
}
